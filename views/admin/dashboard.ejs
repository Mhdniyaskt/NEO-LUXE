<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neo-Luxe | Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #05070A; color: #E2E8F0; font-family: 'Inter', sans-serif; }
        .card-bg { background-color: #0B1120; border: 1px solid #1E293B; }
        .sidebar-bg { background-color: #05070A; border-right: 1px solid #1E293B; }
        
        /* Custom scrollbar for that premium feel */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #05070A; }
        ::-webkit-scrollbar-thumb { background: #1E293B; border-radius: 10px; }
    </style>
</head>
<body class="antialiased overflow-hidden">

    <div class="flex h-screen w-full">
        
       <%- include('../partials/admin-sidebar') %>
        <main class="flex-1 overflow-y-auto p-8">
            <div class="max-w-7xl mx-auto">
                
                <header class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-white uppercase tracking-tight">Watch Store Dashboard</h2>
                        <p class="text-slate-500 text-sm">Overview of sales, orders, and premium inventory.</p>
                    </div>
                    <div class="flex bg-slate-900 rounded-full p-1 text-[10px] font-bold uppercase border border-slate-800">
                        <button class="bg-cyan-500 text-black px-4 py-2 rounded-full">Today</button>
                        <button class="px-4 py-2 text-slate-400">Weekly</button>
                        <button class="px-4 py-2 text-slate-400">Monthly</button>
                    </div>
                </header>

                <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
                    <% const stats = [
                        { label: 'Total Watch Sales', val: '₹12,45,000', trend: '+12%', icon: 'fa-wallet', color: 'text-cyan-500' },
                        { label: 'Total Orders', val: '342', trend: '+5%', icon: 'fa-shopping-cart', color: 'text-cyan-500' },
                        { label: 'Customers', val: '1,205', trend: '+8%', icon: 'fa-user-friends', color: 'text-cyan-500' },
                        { label: 'Watches Listed', val: '85', trend: '+2%', icon: 'fa-box', color: 'text-cyan-500' },
                        { label: 'Low Stock Alerts', val: '12', trend: '-3%', icon: 'fa-exclamation-triangle', color: 'text-red-500' }
                    ] %>
                    <% stats.forEach(stat => { %>
                        <div class="card-bg p-5 rounded-xl">
                            <div class="flex justify-between items-start mb-4">
                                <span class="text-[9px] font-bold text-slate-500 uppercase tracking-widest"><%= stat.label %></span>
                                <i class="fas <%= stat.icon %> <%= stat.color %> text-xs"></i>
                            </div>
                            <div class="text-xl font-bold text-white"><%= stat.val %></div>
                            <div class="text-[10px] <%= stat.color %> mt-2 font-bold"><%= stat.trend %></div>
                        </div>
                    <% }) %>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                    <div class="lg:col-span-2 card-bg p-6 rounded-2xl">
                        <div class="flex justify-between mb-6">
                            <div>
                                <h3 class="font-bold text-sm uppercase">Sales Revenue Trend</h3>
                                <p class="text-[10px] text-slate-500 uppercase">Daily revenue from watch sales</p>
                            </div>
                            <div class="text-right">
                                <span class="text-cyan-400 font-bold text-lg">₹45,000</span>
                                <p class="text-[9px] text-slate-500 uppercase">Today</p>
                            </div>
                        </div>
                        <div class="h-64">
                            <canvas id="revenueChart"></canvas>
                        </div>
                    </div>
                    
                    <div class="card-bg p-6 rounded-2xl">
                        <h3 class="font-bold text-sm uppercase mb-4">Sales by Colors</h3>
                        <p class="text-[10px] text-slate-500 uppercase mb-6">Distribution of watch types sold</p>
                        <div class="h-48 relative flex justify-center">
                            <canvas id="colorChart"></canvas>
                            <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                                <span class="text-2xl font-bold text-white">1,240</span>
                                <span class="text-[9px] text-slate-500 uppercase tracking-tighter">Units</span>
                            </div>
                        </div>
                        <div class="mt-6 space-y-2 text-[10px] uppercase font-bold text-slate-400">
                            <div class="flex justify-between"><span class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-cyan-500"></div> Black</span> <span>40%</span></div>
                            <div class="flex justify-between"><span class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-blue-500"></div> Silver</span> <span>25%</span></div>
                        </div>
                    </div>
                </div>

                <section class="card-bg rounded-2xl overflow-hidden mb-8">
                    <div class="p-6 flex justify-between items-center border-b border-slate-800">
                        <h3 class="font-bold text-sm uppercase">Recent Orders</h3>
                        <button class="text-cyan-500 text-[10px] font-bold uppercase tracking-widest hover:underline">View All</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-xs">
                            <thead class="text-slate-500 text-[10px] uppercase border-b border-slate-800 bg-slate-900/30">
                                <tr>
                                    <th class="px-6 py-4">Order ID</th>
                                    <th class="px-6 py-4">Customer</th>
                                    <th class="px-6 py-4">Watch Model</th>
                                    <th class="px-6 py-4">Amount</th>
                                    <th class="px-6 py-4">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                <tr class="hover:bg-slate-800/30 transition">
                                    <td class="px-6 py-4 text-slate-400">#ORD-7321</td>
                                    <td class="px-6 py-4 text-white font-medium">Arjun Kapoor</td>
                                    <td class="px-6 py-4 text-slate-400">Rolex Submariner Date</td>
                                    <td class="px-6 py-4 font-bold text-white">₹9,50,000</td>
                                    <td class="px-6 py-4"><span class="bg-cyan-900/30 text-cyan-400 px-3 py-1 rounded text-[9px] font-bold border border-cyan-500/20">PAID</span></td>
                                </tr>
                                <tr class="hover:bg-slate-800/30 transition">
                                    <td class="px-6 py-4 text-slate-400">#ORD-7320</td>
                                    <td class="px-6 py-4 text-white font-medium">Sarah Miller</td>
                                    <td class="px-6 py-4 text-slate-400">Apple Watch Ultra 2</td>
                                    <td class="px-6 py-4 font-bold text-white">₹89,900</td>
                                    <td class="px-6 py-4"><span class="bg-yellow-900/30 text-yellow-500 px-3 py-1 rounded text-[9px] font-bold border border-yellow-500/20">PROCESSING</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <footer class="text-center pb-8">
                    <p class="text-[9px] text-slate-600 uppercase tracking-widest">© 2024 VORAODI WATCH E-COMMERCE ADMIN PANEL. ALL RIGHTS RESERVED.</p>
                </footer>
            </div>
        </main>
    </div>

    <script>
        // Chart Configs matching the image style
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        const gradient = ctxRev.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(34, 211, 238, 0.2)');
        gradient.addColorStop(1, 'rgba(34, 211, 238, 0)');

        new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    data: [15, 22, 28, 32, 12, 28, 48],
                    borderColor: '#22D3EE',
                    borderWidth: 3,
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 0,
                    pointHoverRadius: 6
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { display: false },
                    x: { grid: { display: false }, ticks: { color: '#64748b', font: { size: 10 } } }
                }
            }
        });

        const ctxCol = document.getElementById('colorChart').getContext('2d');
        new Chart(ctxCol, {
            type: 'doughnut',
            data: {
                datasets: [{
                    data: [40, 25, 20, 15],
                    backgroundColor: ['#22D3EE', '#3B82F6', '#1E293B', '#0EA5E9'],
                    borderWidth: 0,
                    cutout: '85%'
                }]
            },
            options: { maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });
    </script>
</body>
</html>