<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neo-Luxe | My Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .active-nav-item {
            background: linear-gradient(90deg, rgba(0, 163, 255, 0.1) 0%, rgba(0, 163, 255, 0.02) 100%);
            border-right: 2px solid #00a3ff;
            color: #00a3ff;
        }
    </style>
</head>
<body class="bg-[#05080d] text-white min-h-screen flex flex-col">

   
    <main class="max-w-7xl mx-auto w-full px-6 py-8 flex-grow">
       

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <aside class="lg:col-span-3 bg-[#0a0f18] rounded-3xl border border-gray-800 overflow-hidden py-6">
                <div class="px-6 mb-8 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full border border-gray-700 bg-gray-800 flex items-center justify-center">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-bold">Alexander Doe</h3>
                        <p class="text-[10px] text-[#00a3ff] font-bold uppercase tracking-widest">Premium Member</p>
                    </div>
                </div>

                <nav class="flex flex-col">
                    <a href="#" class="px-6 py-4 flex items-center gap-4 text-sm active-nav-item">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2"></path></svg>
                        Profile
                        <div class="ml-auto w-1.5 h-1.5 rounded-full bg-[#00a3ff]"></div>
                    </a>
                    <a href="#" class="px-6 py-4 flex items-center gap-4 text-sm text-gray-400 hover:text-white transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" stroke-width="2"></path></svg>
                        My Orders
                    </a>
                    <a href="#" class="px-6 py-4 flex items-center gap-4 text-sm text-gray-400 hover:text-white transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" stroke-width="2"></path></svg>
                        Wallet
                    </a>
                    <a href="#" class="px-6 py-4 flex items-center gap-4 text-sm text-gray-400 hover:text-white transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-width="2"></path><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="2"></path></svg>
                        Address
                    </a>
                    <a href="#" class="px-6 py-4 flex items-center gap-4 text-sm text-gray-400 hover:text-white transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" stroke-width="2"></path></svg>
                        Refer & Earn
                    </a>
                    <div class="mt-8 px-6 pt-6 border-t border-gray-800">
                        <a href="#" class="flex items-center gap-4 text-sm text-red-500 hover:text-red-400 transition">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" stroke-width="2"></path></svg>
                            Logout
                        </a>
                    </div>
                </nav>
            </aside>

            <div class="lg:col-span-9 space-y-8">
                
                <div class="bg-[#0a0f18] rounded-3xl border border-gray-800 p-8 flex flex-col md:flex-row items-center gap-8 relative overflow-hidden">
                    <div class="relative">
                        <div class="w-32 h-32 rounded-full border-2 border-[#00a3ff] bg-gray-900 flex items-center justify-center overflow-hidden">
                            <svg class="w-16 h-16 text-gray-700" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"></path></svg>
                        </div>
                        <button class="absolute bottom-1 right-1 bg-[#00a3ff] p-2 rounded-full border-4 border-[#0a0f18] text-white">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke-width="2"></path><path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="2"></path></svg>
                        </button>
                    </div>
                    <div>
                        <h2 class="text-3xl font-bold mb-1">Alexander Doe</h2>
                        <p class="text-gray-500 text-sm">alexander.doe@example.com</p>
                    </div>
                </div>

                <div class="bg-[#0a0f18] rounded-3xl border border-gray-800 p-8">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="bg-cyan-500/10 p-2 rounded-lg text-cyan-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" stroke-width="2"></path></svg>
                        </div>
                        <h3 class="text-lg font-bold">Personal Information</h3>
                    </div>

                    <form class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold">Full Name</label>
                            <div class="relative">
                                <input type="text" value="Alexander Doe" class="w-full bg-[#111827] border border-gray-800 rounded-xl py-3 px-4 text-sm outline-none focus:border-cyan-500 transition">
                                <svg class="w-4 h-4 absolute right-4 top-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2"></path></svg>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold">Email Address</label>
                            <div class="relative">
                                <input type="email" value="alexander.doe@example.com" class="w-full bg-[#111827] border border-gray-800 rounded-xl py-3 px-4 text-sm outline-none focus:border-cyan-500 transition">
                                <svg class="w-4 h-4 absolute right-4 top-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="2"></path></svg>
                            </div>
                        </div>
                        <div class="space-y-2 md:col-span-2 max-w-sm">
                            <label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold">Phone Number</label>
                            <div class="relative">
                                <input type="text" value="+1 (555) 123-4567" class="w-full bg-[#111827] border border-gray-800 rounded-xl py-3 px-4 text-sm outline-none focus:border-cyan-500 transition">
                                <svg class="w-4 h-4 absolute right-4 top-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-width="2"></path></svg>
                            </div>
                        </div>

                        <div class="md:col-span-2 flex flex-wrap gap-4 pt-6">
                            <a href="/editprofile">
                             <button type="button" class="bg-transparent border border-gray-700 hover:bg-gray-800 px-8 py-3 rounded-full text-xs font-bold uppercase tracking-widest transition flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" stroke-width="2"></path></svg>
                                Edit Profile
                            </button>
                            </a>
                            <a href="/changeEmail">
                                <button type="button" class="bg-cyan-500 text-white px-8 py-3 rounded-full text-xs font-bold uppercase tracking-widest transition hover:bg-cyan-600 shadow-lg shadow-cyan-500/20">
                                Change Email
                            </button>
                            </a>
                            <a href="/changePass">
                                 <button type="button" class="bg-cyan-500 text-white px-8 py-3 rounded-full text-xs font-bold uppercase tracking-widest transition hover:bg-cyan-600 shadow-lg shadow-cyan-500/20 flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-width="2"></path></svg>
                                Change Password
                            </button>
                            </a>
                           
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>


</body>
</html>