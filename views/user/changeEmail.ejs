
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Email - NEO-LUXE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-[#020617] text-white font-sans min-h-screen flex flex-col">


    <main class="flex-grow flex flex-col items-center justify-center px-4">
        <div class="w-full max-w-2xl">
            <div class="flex justify-between items-end mb-6">
                <div>
                    <h1 class="text-4xl font-semibold mb-1">change Email</h1>
                    <p class="text-gray-400 text-sm">Update your personal information</p>
                </div>
                <button class="bg-gray-800 hover:bg-gray-700 text-xs py-2 px-4 rounded-md flex items-center gap-2 transition">
                    <i class="fas fa-arrow-left text-[10px]"></i> Back to Profile
                </button>
            </div>

            <div class="bg-[#0f172a] rounded-xl p-8 border border-gray-800 shadow-2xl">
                <h2 class="text-lg font-medium mb-8">Personal Information</h2>
                
                <form class="space-y-6">
                    <div>
                        <label class="block text-[10px] font-bold text-cyan-500 uppercase tracking-widest mb-2">Current Email</label>
                        <input type="email" class="w-full bg-[#020617] border border-gray-700 rounded-lg p-3 focus:outline-none focus:border-cyan-500 transition">
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-cyan-500 uppercase tracking-widest mb-2">New Email</label>
                        <input type="email" class="w-full bg-[#020617] border border-gray-700 rounded-lg p-3 focus:outline-none focus:border-cyan-500 transition">
                    </div>

                    <div class="flex items-center gap-6 pt-4">
                        <button type="submit" class="bg-cyan-400 hover:bg-cyan-300 text-black font-bold py-2 px-8 rounded-lg shadow-[0_0_15px_rgba(34,211,238,0.3)] transition">
                            Verify Email
                        </button>
                        <button type="button" class="text-gray-400 hover:text-white text-sm transition">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </main>


</body>
