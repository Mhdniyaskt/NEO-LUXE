<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customers | NEO-LUXE Admin</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        brand: {
                            darkest: '#05070A',
                            sidebar: '#020408',
                            card: '#0B1120',
                            accent: '#22D3EE',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #05070A; color: #94A3B8; }
        
        /* Custom Scrollbar */
        .custom-scroll::-webkit-scrollbar { width: 6px; }
        .custom-scroll::-webkit-scrollbar-track { background: #05070A; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #1E293B; border-radius: 10px; }
        .custom-scroll::-webkit-scrollbar-thumb:hover { background: #334155; }

        .sidebar-item:hover { background: rgba(34, 211, 238, 0.05); color: white; }
        .sidebar-active { color: #22D3EE; background: rgba(34, 211, 238, 0.05); }
    </style>
</head>
<body class="antialiased overflow-hidden bg-[#05070A] text-slate-300 font-sans">

    <div class="flex h-screen w-full">
        
        <%- include('../partials/admin-sidebar') %>

        <main class="flex-1 overflow-y-auto p-8 custom-scroll">
            
            <header class="mb-10">
                <div class="flex items-center gap-2 text-[10px] text-slate-600 uppercase tracking-[0.2em] mb-3">
                    <i class="fa-solid fa-house text-[8px]"></i> <span>/</span> <span>Admin</span> <span>/</span> <span class="text-cyan-400">Customers</span>
                </div>
                <h1 class="text-3xl font-bold text-white uppercase tracking-tight mb-1">Customers</h1>
                <p class="text-sm text-slate-500 font-light">Manage registered customers and account statuses.</p>
            </header>

            <form action="/admin/customers" method="GET" class="bg-[#0B1120] border border-slate-800/60 p-6 rounded-2xl mb-8 flex items-end gap-4 shadow-xl">
                <div class="flex-[3]">
                    <label class="block text-[10px] uppercase font-bold text-slate-500 mb-3 tracking-widest">Search Customer</label>
                    <div class="relative">
                        <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-600 text-xs"></i>
                        <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Search by name, email or phone..." 
                               class="w-full bg-[#05070A] border border-slate-800 rounded-xl py-3 pl-12 pr-4 text-sm text-white focus:outline-none focus:border-cyan-500/50 transition-all">
                    </div>
                </div>

                <div class="flex-1">
                    <label class="block text-[10px] uppercase font-bold text-slate-500 mb-3 tracking-widest">Status</label>
                    <select name="status" class="w-full bg-[#05070A] border border-slate-800 rounded-xl py-3 px-4 text-sm text-white focus:outline-none focus:border-cyan-500/50 appearance-none cursor-pointer">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="blocked">Blocked</option>
                    </select>
                </div>
                
                <div class="flex gap-3">
                    <a href="/admin/customers" class="bg-slate-800/50 border border-slate-700 hover:bg-slate-700 text-white px-6 py-3 rounded-xl text-[10px] font-bold uppercase tracking-wider transition flex items-center gap-2">
                        <i class="fa-solid fa-filter-circle-xmark"></i> Clear
                    </a>
                    <button type="submit" class="bg-cyan-400 hover:brightness-110 text-black px-10 py-3 rounded-xl text-[10px] font-bold uppercase tracking-wider transition shadow-[0_0_20px_rgba(34,211,238,0.2)] flex items-center gap-2">
                        <i class="fa-solid fa-magnifying-glass"></i> Search
                    </button>
                </div>
            </form>

            <section class="bg-[#0B1120] border border-slate-800/60 rounded-2xl overflow-hidden shadow-2xl">
                <div class="px-8 py-6 border-b border-slate-800/60 flex justify-between items-center bg-slate-900/10">
                    <h2 class="font-bold flex items-center gap-3 text-white text-xs uppercase tracking-[0.15em]">
                        <i class="fa-solid fa-users text-cyan-400"></i> Registered Users
                    </h2>
                    <span class="text-[10px] text-slate-500 uppercase tracking-widest font-medium">
                        Showing 1 to <%= customers.length %> of 1,248 customers
                    </span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-900/40 text-[10px] uppercase tracking-[0.15em] text-slate-500 border-b border-slate-800/60">
                            <tr>
                                <th class="px-8 py-5 font-bold">Customer Name</th>
                                <th class="px-6 py-5 font-bold">Email Address</th>
                                <th class="px-6 py-5 font-bold">Phone Number</th>
                                <th class="px-6 py-5 font-bold">Joined Date</th>
                                <th class="px-6 py-5 font-bold text-center">Status</th>
                                <th class="px-8 py-5 font-bold text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/40">
                            <% if (customers && customers.length > 0) { %>
                                <% customers.forEach(user => { %>
                                    <tr class="hover:bg-white/[0.02] transition-colors group">
                                        <td class="px-8 py-5">
                                            <div class="flex items-center gap-4">
                                                <div class="w-9 h-9 rounded-full bg-slate-800 flex items-center justify-center text-[10px] text-cyan-400 font-bold border border-slate-700 group-hover:border-cyan-400/30 transition-all">
                                                    <%= user.name ? user.name.split(' ').map(n => n[0]).join('').toUpperCase() : 'U' %>
                                                </div>
                                                <span class="font-semibold text-white text-sm"><%= user.name %></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 text-slate-400 text-xs font-light"><%= user.email %></td>
                                        <td class="px-6 py-5 text-slate-400 text-xs font-light tracking-wide"><%= user.phoneNumber || '+91 00000 00000' %></td>
                                        <td class="px-6 py-5 text-slate-500 text-[11px] font-medium">
                                            <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                        </td>
                                        <td class="px-6 py-5 text-center">
                                            <span class="inline-block px-3 py-1 rounded-md text-[9px] font-black uppercase tracking-tighter border <%= user.isBlocked ? 'bg-red-500/10 text-red-500 border-red-500/20' : 'bg-cyan-500/10 text-cyan-400 border-cyan-400/20' %>">
                                                <%= user.isBlocked ? 'Blocked' : 'Active' %>
                                            </span>
                                        </td>
                                        <td class="px-8 py-5 text-right">
    <form action="/admin/customers/toggle/<%= user._id %>?_method=PATCH" method="POST">
        <button type="submit" 
            class="text-[9px] font-black uppercase tracking-widest border px-4 py-2 rounded-lg transition-all 
            <%= user.isBlocked ? 'text-cyan-400 border-cyan-400/20 hover:bg-cyan-400 hover:text-black' : 'text-slate-500 border-slate-800 hover:text-red-500 hover:border-red-500/40' %>">
            <%= user.isBlocked ? 'Unblock User' : 'Block User' %>
        </button>
    </form>
</td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="px-6 py-24 text-center text-slate-600 uppercase text-[10px] tracking-[0.3em] font-bold">No registered customers found</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                
                <div class="p-6 border-t border-slate-800/60 flex justify-between items-center bg-slate-900/5">
                    <p class="text-slate-600 uppercase tracking-widest text-[9px] font-bold">Showing 1 to <%= customers.length %> entries</p>
                    <div class="flex gap-2">
                        <button class="w-8 h-8 rounded-lg border border-slate-800 flex items-center justify-center hover:bg-slate-800 transition text-slate-500"><i class="fa-solid fa-chevron-left text-[10px]"></i></button>
                        <button class="w-8 h-8 rounded-lg bg-cyan-400 text-black font-bold text-[10px]">1</button>
                        <button class="w-8 h-8 rounded-lg border border-slate-800 text-slate-500 font-bold text-[10px] hover:bg-slate-800">2</button>
                        <button class="w-8 h-8 rounded-lg border border-slate-800 text-slate-500 font-bold text-[10px] hover:bg-slate-800">3</button>
                        <span class="text-slate-700 px-1 self-center">...</span>
                        <button class="w-8 h-8 rounded-lg border border-slate-800 text-slate-500 font-bold text-[10px] hover:bg-slate-800">12</button>
                        <button class="w-8 h-8 rounded-lg border border-slate-800 flex items-center justify-center hover:bg-slate-800 transition text-slate-500"><i class="fa-solid fa-chevron-right text-[10px]"></i></button>
                    </div>
                </div>
            </section>

            <footer class="mt-16 mb-8 text-center text-[9px] text-slate-700 uppercase tracking-[0.4em] font-medium">
                © 2024 WATCH STORE ADMIN PANEL. ALL RIGHTS RESERVED.
            </footer>
        </main>
    </div>

    <style>
        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: #05070A; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #1E293B; border-radius: 10px; }
        .custom-scroll::-webkit-scrollbar-thumb:hover { background: #22D3EE; }
    </style>
</body>
</html>