<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Addresses - NEO-LUXE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .modal-active { display: flex !important; }
    </style>
</head>
<body class="bg-[#020617] text-white font-sans min-h-screen flex flex-col">

    

    <main class="flex-grow max-w-7xl mx-auto w-full px-8 py-10">
        <nav class="text-[10px] text-gray-500 uppercase tracking-widest mb-8">
            Home <span class="mx-2">›</span> <span class="text-gray-300">My Addresses</span>
        </nav>

        <div class="flex flex-col lg:flex-row gap-8">
            <aside class="w-full lg:w-64 flex-shrink-0">
                <div class="bg-[#0f172a] rounded-xl border border-gray-800 overflow-hidden">
                    <div class="p-6 flex items-center gap-4 border-b border-gray-800">
                        <div class="w-12 h-12 bg-gray-800 rounded-full flex items-center justify-center border border-gray-700">
                            <i class="far fa-user text-gray-400"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold">Alexander Doe</h3>
                            <p class="text-[10px] text-gray-500">Premium Member</p>
                        </div>
                    </div>
                    <nav class="py-4">
                        <a href="#" class="flex items-center gap-3 px-6 py-3 text-sm text-gray-400 hover:bg-gray-800 transition"><i class="far fa-user w-5"></i> Profile</a>
                        <a href="#" class="flex items-center gap-3 px-6 py-3 text-sm text-cyan-400 bg-cyan-400/5 border-r-2 border-cyan-400 transition"><i class="fas fa-map-marker-alt w-5"></i> Address</a>
                        <a href="#" class="flex items-center gap-3 px-6 py-3 text-sm text-red-400 hover:bg-red-400/5 transition mt-4"><i class="fas fa-sign-out-alt w-5"></i> Logout</a>
                    </nav>
                </div>
            </aside>

            <section class="flex-grow">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h1 class="text-3xl font-bold mb-2">My Addresses</h1>
                        <p class="text-gray-400 text-sm">Manage your saved delivery addresses</p>
                    </div>
                    <button onclick="toggleModal('add')" class="bg-cyan-400 hover:bg-cyan-300 text-black text-xs font-bold py-3 px-6 rounded-full shadow-[0_0_20px_rgba(34,211,238,0.3)] flex items-center gap-2 transition">
                        <i class="fas fa-plus"></i> Add New Address
                    </button>
                </div>

                <div class="bg-[#0f172a] rounded-xl border border-gray-800 p-8 max-w-xl relative">
                    <div class="flex justify-between items-start mb-4">
                        <span class="bg-cyan-400/10 text-cyan-400 text-[9px] font-bold px-3 py-1 rounded uppercase tracking-widest">Home</span>
                        <div class="flex gap-4 text-gray-500">
                            <button onclick="toggleModal('edit')" class="hover:text-white transition"><i class="fas fa-pencil-alt text-xs"></i></button>
                            <button class="hover:text-red-400 transition"><i class="far fa-trash-alt text-xs"></i></button>
                        </div>
                    </div>
                    <h3 class="text-lg font-bold mb-2">Alexander Doe</h3>
                    <p class="text-gray-400 text-sm mb-6">123 Luxury Avenue, Penthouse Suite 4B,<br>Beverly Hills, CA 90210</p>
                    <div class="pt-6 border-t border-gray-800 text-gray-400 text-sm flex items-center gap-3">
                        <i class="fas fa-phone-alt text-xs"></i> +1 (555) 123-4567
                    </div>
                </div>
            </section>
        </div>
    </main>

    <div id="addressModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4 z-50">
        <div class="w-full max-w-2xl bg-[#1e293b] rounded-[2rem] shadow-2xl overflow-hidden border border-gray-700/50">
            <div class="flex justify-between items-center px-8 py-6">
                <h2 id="modalTitle" class="text-white text-xl font-semibold">Add New Address</h2>
                <button onclick="toggleModal()" class="text-gray-400 hover:text-white transition"><i class="fas fa-times text-lg"></i></button>
            </div>

            <form class="px-8 pb-8 space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="space-y-1">
                        <label class="text-[11px] font-medium text-gray-400 ml-1">Full Name</label>
                        <input type="text" class="w-full bg-[#334155] text-white rounded-xl p-3.5 focus:ring-1 focus:ring-cyan-500 outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[11px] font-medium text-gray-400 ml-1">Mobile Number</label>
                        <input type="tel" class="w-full bg-[#334155] text-white rounded-xl p-3.5 focus:ring-1 focus:ring-cyan-500 outline-none">
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-[11px] font-medium text-gray-400 ml-1">Address Line 1</label>
                    <input type="text" class="w-full bg-[#334155] text-white rounded-xl p-3.5 focus:ring-1 focus:ring-cyan-500 outline-none">
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                    <input type="text" placeholder="City" class="w-full bg-[#334155] text-white rounded-xl p-3.5 focus:ring-1 focus:ring-cyan-500 outline-none">
                    <input type="text" placeholder="State" class="w-full bg-[#334155] text-white rounded-xl p-3.5 focus:ring-1 focus:ring-cyan-500 outline-none">
                    <input type="text" placeholder="Pincode" class="w-full bg-[#334155] text-white rounded-xl p-3.5 focus:ring-1 focus:ring-cyan-500 outline-none">
                </div>
                
                <div class="space-y-3">
                    <label class="text-[11px] font-medium text-gray-400">Address Type</label>
                    <div class="flex gap-4">
                        <label class="flex items-center gap-2 px-5 py-2.5 rounded-full border border-cyan-500 bg-cyan-500/10 cursor-pointer text-sm">
                            <input type="radio" name="type" checked class="accent-cyan-400"> Home
                        </label>
                        <label class="flex items-center gap-2 px-5 py-2.5 rounded-full border border-gray-600 cursor-pointer text-sm text-gray-400">
                            <input type="radio" name="type" class="accent-cyan-400"> Office
                        </label>
                    </div>
                </div>
            </form>

            <div class="bg-[#2d3a4d] px-8 py-5 flex justify-end items-center gap-6">
                <button onclick="toggleModal()" class="text-gray-400 hover:text-white text-sm">Cancel</button>
                <button id="saveBtn" class="bg-cyan-400 hover:bg-cyan-300 text-black font-bold py-2.5 px-8 rounded-full shadow-[0_0_15px_rgba(34,211,238,0.4)] transition">
                    Save Address
                </button>
            </div>
        </div>
    </div>

    <script>
        function toggleModal(mode) {
            const modal = document.getElementById('addressModal');
            const title = document.getElementById('modalTitle');
            const saveBtn = document.getElementById('saveBtn');

            if (mode === 'add') {
                title.innerText = "Add New Address";
                saveBtn.innerText = "Save Address";
                modal.classList.add('modal-active');
            } else if (mode === 'edit') {
                title.innerText = "Edit Address";
                saveBtn.innerText = "Save Changes";
                modal.classList.add('modal-active');
            } else {
                modal.classList.remove('modal-active');
            }
        }
    </script>
</body>
