<nav class="bg-[#0a0f18] text-white px-6 py-4 border-b border-gray-800 relative">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    
    <div class="flex items-center gap-2 flex-shrink-0">
      <div class="text-cyan-500">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
      </div>
      <span class="text-xl font-bold tracking-tighter uppercase">Neo-Luxe</span>
    </div>

    <div class="hidden md:flex items-center gap-8 text-sm font-medium ml-12">
      <a href="/" class="text-cyan-400">Home</a>
      <a href="#" class="hover:text-cyan-400 transition-colors">Shop</a>
      <a href="#" class="hover:text-cyan-400 transition-colors">About</a>
    </div>

    <div class="flex items-center gap-6 flex-1 justify-end">
      <div class="flex items-center gap-4 text-gray-300">
        <button class="hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
        </button>

        <button class="relative hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </button>

        <div class="relative">
          <button id="profile-toggle" class="hover:text-white transition-colors pt-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </button>

          <div id="profile-dropdown" class="hidden absolute right-0 mt-4 w-72 bg-[#1a1a1a] rounded-3xl p-6 shadow-2xl border border-gray-800 z-[60]">
            
            <% if(!isLoggedIn) { %>
                <h4 class="text-xs font-bold text-gray-500 tracking-[0.2em] uppercase mb-6">Welcome</h4>
                <div class="space-y-3">
                    <a href="/login" class="block w-full text-center bg-[#0095ff] hover:bg-[#0084e6] text-white font-bold py-4 rounded-full shadow-[0_0_20px_rgba(0,149,255,0.3)] transition-all active:scale-95">
                        Log In
                    </a>
                    <a href="/signup" class="block w-full text-center bg-[#242424] hover:bg-[#2a2a2a] text-white font-bold py-4 rounded-full border border-gray-700 transition-all active:scale-95">
                        Create Account
                    </a>
                </div>
            <% } else { %>
                <h4 class="text-xs font-bold text-gray-500 tracking-[0.2em] uppercase mb-6">Member Area</h4>
                <div class="space-y-3">
                    <a href="/profile" class="block w-full text-center bg-[#242424] hover:bg-[#2a2a2a] text-white font-bold py-4 rounded-full border border-gray-700 transition-all active:scale-95">
                        My Profile
                    </a>
                    <a href="/logout" class="block w-full text-center bg-red-500/10 hover:bg-red-500/20 text-red-500 font-bold py-4 rounded-full border border-red-500/20 transition-all active:scale-95">
                        Logout
                    </a>
                </div>
            <% } %>

          </div>
        </div>

        <button id="menu-toggle" class="md:hidden text-white ml-2 focus:outline-none">
          <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#0a0f18] border-t border-gray-800 md:hidden z-50">
    <div class="flex flex-col p-6 space-y-4 font-medium">
      <a href="/" class="text-cyan-400">Home</a>
      <a href="#" class="hover:text-cyan-400 transition-colors">Shop</a>
      <a href="#" class="hover:text-cyan-400 transition-colors">About</a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const profileBtn = document.getElementById('profile-toggle');
  const profileDropdown = document.getElementById('profile-dropdown');

  // Mobile Menu Toggle
  menuBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    mobileMenu.classList.toggle('hidden');
    profileDropdown.classList.add('hidden'); 
    
    if (mobileMenu.classList.contains('hidden')) {
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>';
    } else {
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
    }
  });

  // Profile Dropdown Toggle
  profileBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    profileDropdown.classList.toggle('hidden');
    mobileMenu.classList.add('hidden'); 
  });

  // Close menus when clicking outside
  window.addEventListener('click', () => {
    profileDropdown.classList.add('hidden');
    mobileMenu.classList.add('hidden');
    menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>';
  });

  // Prevent closing when clicking inside the dropdown
  profileDropdown.addEventListener('click', (e) => e.stopPropagation());
</script>  