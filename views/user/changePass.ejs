<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - NEO-LUXE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-[#020617] text-white font-sans min-h-screen flex flex-col">

    <main class="flex-grow flex flex-col items-center justify-center px-4 py-10">
        <div class="w-full max-w-2xl">
            <div class="flex justify-between items-end mb-8">
                <div>
                    <h1 class="text-4xl font-bold mb-2">Change Password</h1>
                    <p class="text-gray-400 text-sm">Update your account password</p>
                </div>
                <a href="/profile" class="border border-gray-700 hover:bg-gray-800 text-[10px] py-2 px-4 rounded-full flex items-center gap-2 transition uppercase tracking-widest text-cyan-400">
                    <i class="fas fa-arrow-left text-[9px]"></i> Back to Profile
                </a>
            </div>

            <div class="bg-[#0f172a]/80 backdrop-blur-sm rounded-2xl p-10 border border-gray-800 shadow-2xl">
                <h2 class="text-lg font-medium mb-10 border-b border-gray-800 pb-4">Password Information</h2>
                
                <form id="changePasswordForm" class="space-y-6">
                    <div class="relative">
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Current Password</label>
                        <div class="relative">
                            <input type="password" name="currentPassword" required class="w-full bg-[#020617] border border-gray-800 rounded-lg p-3.5 focus:outline-none focus:border-cyan-500 transition pr-12">
                            <i class="far fa-eye absolute right-4 top-4 text-gray-600 cursor-pointer hover:text-cyan-500 toggle-pwd"></i>
                        </div>
                        <div class="text-right mt-2">
                            <button type="button" onclick="requestOTP()" class="text-[10px] text-gray-500 hover:text-cyan-400 transition uppercase tracking-tighter">Forgot Password?</button>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">New Password</label>
                        <div class="relative">
                            <input type="password" name="newPassword" required class="w-full bg-[#020617] border border-gray-800 rounded-lg p-3.5 focus:outline-none focus:border-cyan-500 transition pr-12">
                            <i class="far fa-eye absolute right-4 top-4 text-gray-600 cursor-pointer hover:text-cyan-500 toggle-pwd"></i>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Confirm New Password</label>
                        <div class="relative">
                            <input type="password" name="confirmPassword" required class="w-full bg-[#020617] border border-gray-800 rounded-lg p-3.5 focus:outline-none focus:border-cyan-500 transition pr-12">
                            <i class="far fa-eye absolute right-4 top-4 text-gray-600 cursor-pointer hover:text-cyan-500 toggle-pwd"></i>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 pt-8">
                        <button type="submit" class="bg-cyan-400 hover:bg-cyan-300 text-black font-extrabold py-3 px-10 rounded-full shadow-[0_0_20px_rgba(34,211,238,0.25)] transition-all transform hover:scale-105">
                            Update Password
                        </button>
                        <a href="/profile" class="bg-gray-800 hover:bg-gray-700 text-gray-300 font-bold py-3 px-10 rounded-full transition text-center">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        // Password Visibility Toggle
        document.querySelectorAll('.toggle-pwd').forEach(btn => {
            btn.addEventListener('click', function() {
                const input = this.previousElementSibling;
                const isPwd = input.type === 'password';
                input.type = isPwd ? 'text' : 'password';
                this.classList.toggle('fa-eye', !isPwd);
                this.classList.toggle('fa-eye-slash', isPwd);
            });
        });

        // Handle Form Submit (AJAX)
        document.getElementById('changePasswordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch('/profile/change-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: result.message,
                        background: '#0f172a', color: '#fff', confirmButtonColor: '#22d3ee'
                    });
                    window.location.href = '/profile';
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Validation Error',
                        text: result.message,
                        background: '#0f172a', color: '#fff'
                    });
                }
            } catch (err) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong!', background: '#0f172a', color: '#fff' });
            }
        });

        // Handle Forgot Password OTP (AJAX)
        async function requestOTP() {
            try {
                const response = await fetch('/forgot-password/authenticated');
                const result = await response.json();

                if (result.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'OTP Sent',
                        text: result.message,
                        background: '#0f172a', color: '#fff', confirmButtonColor: '#22d3ee'
                    });
                    window.location.href = '/verify-otp';
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: result.message, background: '#0f172a', color: '#fff' });
                }
            } catch (err) {
                console.error(err);
            }
        }
    </script>
</body>
</html>